# Plantilla de variables de entorno — copiar a `.env` y completar.
# El `.env` real NUNCA se versiona (está en .gitignore).

# Obligatoria. Generar con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambiame-por-una-clave-generada

DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
LOG_LEVEL=INFO

# Conexión completa en una sola variable (motor, credenciales, host, puerto).
# PostgreSQL (producción):
#   DATABASE_URL=postgres://usuario:password@localhost:5432/tiendita_marian
# SQLite (desarrollo rápido, es el default si se omite):
#   DATABASE_URL=sqlite:///db.sqlite3
DATABASE_URL=postgres://tiendita:tiendita@localhost:5432/tiendita_marian

# Frontend Vite
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Correo. En desarrollo, `console` imprime el mail en la terminal.
# Con MailHog levantado: django.core.mail.backends.smtp.EmailBackend + localhost:1025
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@tienditademarian.com
CONTACTO_EMAIL=contacto@tienditademarian.com

# Solo producción (config.settings.prod)
# SECURE_HTTPS=True
# CSRF_TRUSTED_ORIGINS=https://tienditademarian.com
